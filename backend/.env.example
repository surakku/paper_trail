# Neo4j AuraDB
NEO4J_URI=neo4j+s://<your-aura-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-password>

# Modal LLM — OpenAI-compatible endpoint deployed on Modal
MODAL_LLM_URL=https://<your-modal-app>--<endpoint>.modal.run/v1
MODAL_LLM_MODEL=<model-name>
# If your Modal endpoint requires an API key, set it here (otherwise leave blank)
MODAL_LLM_API_KEY=

# RocketRide engine (local: ws://localhost:8765, or cloud URL)
ROCKETRIDE_URI=ws://localhost:8765

# Web search — use one or both
TAVILY_API_KEY=
# duckduckgo-search requires no key

# Semantic Scholar (optional — raises rate limit)
SEMANTIC_SCHOLAR_API_KEY=

# CORS origin for local dev
FRONTEND_ORIGIN=http://localhost:3000
