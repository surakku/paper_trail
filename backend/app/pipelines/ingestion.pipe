{
  "version": "1.0",
  "name": "Ingestion Pipeline",
  "description": "Fetches papers from ArXiv/Semantic Scholar/PDF/URL, extracts concepts, embeds, and writes to Neo4j.",
  "components": [
    {
      "id": "input",
      "type": "input",
      "provider": "input",
      "label": "Input",
      "config": {}
    },
    {
      "id": "llm_concepts",
      "type": "llm",
      "provider": "openai",
      "label": "Concept Extraction",
      "config": {
        "base_url": "https://magiswarm--qwen35-9b-serve.modal.run/v1",
        "model": "qwen35-9b",
        "temperature": 0.3,
        "instructions": "Extract 3-8 key research concepts from this paper abstract as a JSON array of strings."
      }
    },
    {
      "id": "output",
      "type": "output",
      "provider": "output",
      "label": "Output",
      "config": {}
    }
  ],
  "connections": [
    {
      "source": "input",
      "target": "llm_concepts"
    },
    {
      "source": "llm_concepts",
      "target": "output"
    }
  ],
  "project_id": "ce2fea0b-1f1f-4b36-bd4e-7c99b5cbc322"
}