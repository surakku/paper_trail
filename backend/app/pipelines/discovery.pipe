{
  "version": "1.0",
  "name": "Discovery Pipeline",
  "description": "Finds connections between concepts/papers in the knowledge graph and explains them.",
  "components": [
    {
      "id": "input",
      "type": "input",
      "provider": "input",
      "label": "Input",
      "config": {}
    },
    {
      "id": "llm_discovery",
      "type": "llm",
      "provider": "openai",
      "label": "Connection Explainer",
      "config": {
        "base_url": "https://magiswarm--qwen35-9b-serve.modal.run/v1",
        "model": "qwen35-9b",
        "temperature": 0.7,
        "instructions": "Explain the connections between these research concepts and papers, highlighting surprising relationships."
      }
    },
    {
      "id": "output",
      "type": "output",
      "provider": "output",
      "label": "Output",
      "config": {}
    }
  ],
  "connections": [
    {
      "source": "input",
      "target": "llm_discovery"
    },
    {
      "source": "llm_discovery",
      "target": "output"
    }
  ],
  "project_id": "ad7b34f4-6dbf-4fc2-ad72-c2f8dcb8277e"
}