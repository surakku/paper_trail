{
  "version": 1,
  "name": "Summarization Pipeline",
  "description": "Fetches a paper by ID from Neo4j and generates a structured summary.",
  "components": [
    {
      "id": "input",
      "provider": "input",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "measured": {
          "width": 150,
          "height": 37
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "llm_summary",
      "provider": "openai",
      "config": {
        "base_url": "https://magiswarm--qwen35-9b-serve.modal.run/v1",
        "model": "qwen35-9b",
        "temperature": 0.5,
        "instructions": "Produce a structured summary with: TL;DR, Key Contributions, Methods, Results, Limitations."
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "measured": {
          "width": 150,
          "height": 37
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "output",
      "provider": "output",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "measured": {
          "width": 150,
          "height": 37
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "db_neo4j_1",
      "provider": "db_neo4j",
      "config": {
        "profile": "default",
        "default": {
          "auth_method": "userpass",
          "database": "neo4j",
          "db_description": "",
          "max_attempts": 5,
          "uri": "neo4j://localhost:7687"
        }
      },
      "ui": {
        "position": {
          "x": 168,
          "y": -66
        },
        "measured": {
          "width": 150,
          "height": 121
        },
        "nodeType": "default",
        "formDataValid": true
      }
    }
  ],
  "connections": [
    {
      "source": "input",
      "target": "llm_summary"
    },
    {
      "source": "llm_summary",
      "target": "output"
    }
  ],
